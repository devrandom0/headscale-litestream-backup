# =============================================================================
# Headscale + Litestream Backup - Environment Configuration
# =============================================================================

# --- Litestream Toggle ---
# Set to "false" to run headscale directly without replication (useful for local dev)
# LITESTREAM_ENABLED=true

# --- S3-Compatible Storage (REQUIRED when LITESTREAM_ENABLED=true) ---
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=headscale-backup
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1

# --- Litestream Tuning (optional) ---
# LITESTREAM_SYNC_INTERVAL=10s
# LITESTREAM_RETENTION=24h
# LITESTREAM_RETENTION_CHECK_INTERVAL=1h
# LITESTREAM_SNAPSHOT_INTERVAL=6h

# --- Headscale (optional overrides) ---
# HEADSCALE_DB_PATH=/var/lib/headscale/db.sqlite
